from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from datetime import datetime

app = FastAPI()

# Autorisation pour ton site Tiiny.site
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

class MatchRequest(BaseModel):
    team1: str
    team2: str

@app.post("/predict")
async def predict(request: MatchRequest):
    # Logique de prédiction dynamique
    t1 = request.team1
    t2 = request.team2
    
    # Calcul simple et dynamique
    force1 = (sum(ord(c) for c in t1) % 40) + 50
    force2 = (sum(ord(c) for c in t2) % 40) + 50
    
    return {
        "success": True,
        "match": f"{t1} vs {t2}",
        "prediction": {
            "predicted_score": [2, 1],
            "confidence_level": 85
        }
    }
